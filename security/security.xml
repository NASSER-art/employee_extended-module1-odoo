<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_employee_extended_user" model="res.groups">
        <field name="name">Employee Extended: Utilisateur</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
    </record>

    <record id="group_employee_extended_manager" model="res.groups">
        <field name="name">Employee Extended: Manager</field>
        <field name="category_id" ref="base.module_category_human_resources"/>
        <field name="implied_ids" eval="[(4, ref('employee_extended.group_employee_extended_user'))]"/>
    </record>

    <record id="hr.group_hr_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('employee_extended.group_employee_extended_manager'))]"/>
    </record>

    <record id="rule_permit_alert_hr_user" model="ir.rule">
        <field name="name">Alertes permis: utilisateur RH</field>
        <field name="model_id" ref="employee_extended.model_hr_permit_alert"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_permit_alert_hr_manager" model="ir.rule">
        <field name="name">Alertes permis: manager RH</field>
        <field name="model_id" ref="employee_extended.model_hr_permit_alert"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
