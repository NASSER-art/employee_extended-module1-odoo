<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron: Vérification quotidienne des permis de conduire (toutes les 5 minutes pour les tests) -->
    <record id="ir_cron_check_permit_expiry" model="ir.cron">
        <field name="name">Vérification expiration permis de conduire</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_permit_expiry()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="doall" eval="False"/>
        <field name="priority">10</field>
    </record>

    <!-- Cron: Vérification quotidienne des CDD expirés -->
    <record id="ir_cron_check_cdd_expiry" model="ir.cron">
        <field name="name">Vérification expiration CDD et conversion CDI</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_cdd_expiry_tunisia()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="doall" eval="False"/>
        <field name="priority">15</field>
    </record>

    <!-- Cron: Vérification quotidienne des périodes d'essai -->
    <record id="ir_cron_check_trial_period" model="ir.cron">
        <field name="name">Vérification fin période d'essai</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_trial_period_tunisia()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="doall" eval="False"/>
        <field name="priority">20</field>
    </record>
</odoo>