    <!-- Email Template for Permit Expiry -->
    <record id="email_template_permit_expiry" model="mail.template">
        <field name="name">Expiration de Permis: Alerte Employé</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="auto_delete" eval="False"/>
        <field name="subject">⚠️ Alerte Expiration Votre Permis de Conduire - {{ object.name }}</field>
        <field name="email_from">"Moderne metale RH" &lt;nasserletaif4@gmail.com&gt;</field>
        <field name="body_html" type="xml">
            <div style="margin: 0px; padding: 0px; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
                <p>Bonjour,</p>
                <p>Ceci est une alerte automatique concernant l'expiration prochaine du permis de conduire de l'employé suivant :</p>
                <ul>
                    <li><strong>Employé :</strong> <t t-out="object.name"/></li>
                    <li><strong>Département :</strong> <t t-out="object.department_id.name"/></li>
                    <li><strong>Catégorie Permis :</strong> <t t-out="object.driving_permit_category"/></li>
                    <li><strong>Date d'expiration :</strong> <t t-out="object.permis_end_date"/></li>
                    <li><strong>Jours restants :</strong> <t t-out="object.permis_days_remaining"/> jours</li>
                </ul>
                <p>Merci de prendre les mesures nécessaires.</p>
                <br/>
                <p>Cordialement,</p>
                <p>Système GRH</p>
            </div>
