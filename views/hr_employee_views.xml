<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================== -->
    <!-- Formulaire employé étendu                          -->
    <!-- ================================================== -->
    <record id="view_employee_form_extended" model="ir.ui.view">
        <field name="name">hr.employee.form.extended</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <data>

                <!-- Important: déclarer les champs utilisés dans attrs pour que Odoo puisse les évaluer -->
                <xpath expr="//sheet" position="inside">
                    <group invisible="1">
                        <field name="contract_type_extended"/>
                        <field name="contract_id"/>
                        <field name="contract_end_date"/>
                    </group>
                </xpath>

                <!-- Pages des tabs sont définies dans des fichiers séparés -->
                <!-- - hr_employee_education_views.xml -->
                <!-- - hr_employee_social_views.xml -->
                <!-- - hr_employee_permit_views.xml -->
                <!-- - hr_employee_contract_views.xml -->
                <!-- - hr_employee_amplitude_views.xml -->

                <xpath expr="//notebook" position="inside">
                    <page string="Éducation" name="page_education" groups="hr.group_hr_user"/>
                    <page string="Social" name="page_social" groups="hr.group_hr_user"/>
                    <page string="Permis de conduire" name="page_permit" groups="hr.group_hr_user"/>
                    <page string="Contrat étendu" name="page_contract_ext" groups="hr.group_hr_user"/>
                    <page string="Fiche d'amplitude" name="page_fiche_amplitude" groups="hr.group_hr_user"/>
                </xpath>

            </data>
        </field>
    </record>

    <!-- ================================================== -->
    <!-- Vue Liste (Tree) employé étendu                    -->
    <!-- ================================================== -->
    <record id="view_employee_tree_extended" model="ir.ui.view">
        <field name="name">hr.employee.tree.extended</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='department_id']" position="after">
                <field name="contract_type_extended" optional="show"/>
                <field name="education_level" optional="hide"/>
                <field name="cin_number" optional="hide"/>
                <field name="permis_status" widget="badge" optional="hide"
                       decoration-success="permis_status == 'valid'"
                       decoration-warning="permis_status == 'warning'"
                       decoration-danger="permis_status in ('critical', 'expired')"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================== -->
    <!-- Vue Recherche étendue                              -->
    <!-- ================================================== -->
    <record id="view_employee_search_extended" model="ir.ui.view">
        <field name="name">hr.employee.search.extended</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='my_department']" position="after">
                <separator/>
                <filter string="CDI" name="filter_cdi"
                        domain="[('contract_type_extended', '=', 'cdi')]"/>
                <filter string="CDD" name="filter_cdd"
                        domain="[('contract_type_extended', '=', 'cdd')]"/>
                <separator/>
                <filter string="En période d'essai" name="filter_trial"
                        domain="[('is_trial_period', '=', True)]"/>
                <filter string="CDD converti en CDI" name="filter_converted"
                        domain="[('cdd_converted_to_cdi', '=', True)]"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="Type de contrat" name="group_contract_type"
                        context="{'group_by': 'contract_type_extended'}"/>
                <filter string="Niveau d'éducation" name="group_education"
                        context="{'group_by': 'education_level'}"/>
            </xpath>
        </field>
    </record>



</odoo>