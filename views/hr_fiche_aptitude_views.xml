<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= FORM ================= -->
    <record id="view_hr_fiche_aptitude_form" model="ir.ui.view">
        <field name="name">hr.fiche.aptitude.form</field>
        <field name="model">hr.fiche.aptitude</field>
        <field name="arch" type="xml">
            <form create="False">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="examination_date"/>
                            <field name="next_examination_date"/>
                        </group>
                    </group>

                    <group>
                        <group string="Type">
                            <field name="exam_type_id"/>
                            <field name="exam_type_code"/>
                        </group>
                        <group string="Durée">
                            <field name="validity_months"/>
                            <field name="validity_extra_days"/>
                            <field name="expiry_date"/>
                        </group>
                    </group>

                    <group string="Conclusion">
                        <field name="aptitude_result" widget="radio"/>
                        <field name="aptitude_details"/>
                    </group>

                    <group string="Médecin">
                        <field name="doctor_name"/>
                        <field name="medical_center"/>
                    </group>

                    <group string="Observations">
                        <field name="restrictions"/>
                        <field name="notes"/>
                    </group>

                    <group string="Document">
                        <field name="document"/>
                        <field name="document_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================= TREE ================= -->
    <record id="view_hr_fiche_aptitude_tree" model="ir.ui.view">
        <field name="name">hr.fiche.aptitude.tree</field>
        <field name="model">hr.fiche.aptitude</field>
        <field name="arch" type="xml">
            <tree create="False">
                <field name="employee_id"/>
                <field name="exam_type_id"/>
                <field name="examination_date"/>
                <field name="expiry_date"/>
                <field name="aptitude_result"/>
            </tree>
        </field>
    </record>

    <!-- ================= SEARCH ================= -->
    <record id="view_hr_fiche_aptitude_search" model="ir.ui.view">
        <field name="name">hr.fiche.aptitude.search</field>
        <field name="model">hr.fiche.aptitude</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="exam_type_id"/>

                <filter string="Actif" name="filter_active" domain="[('active','=',True)]"/>
                <filter string="À renouveler" name="filter_to_renew"
                        domain="[('expiry_date','&lt;=',context_today())]"/>
            </search>
        </field>
    </record>

    <!-- ================= ACTION ================= -->
    <record id="action_hr_fiche_aptitude" model="ir.actions.act_window">
        <field name="name">Fiches d'aptitude</field>
        <field name="res_model">hr.fiche.aptitude</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ================= MENU ================= -->
    <menuitem id="menu_hr_fiche_aptitude_list"
              name="Fiches d'aptitude"
              action="action_hr_fiche_aptitude"
              parent="employee_extended.menu_fiche_amplitude_root"
              sequence="5"/>

    <!-- ================= WIZARD ================= -->
    <record id="view_medical_exam_wizard_form" model="ir.ui.view">
        <field name="name">medical.exam.wizard.form</field>
        <field name="model">medical.exam.wizard</field>
        <field name="arch" type="xml">
            <form string="INTRO / MODIF FICHE D'APTITUDE AU TRAVAIL">
                <h2>INTRO / MODIF FICHE D'APTITUDE AU TRAVAIL</h2>
                <div class="alert alert-info" role="alert">
                    <strong>Info:</strong> Les champs seront pré-remplis si une fiche d'aptitude existe déjà pour cet employé. Sinon, veuillez les remplir manuellement.
                </div>

                <group>
                    <group>
                        <field name="employee_id"/>
                    </group>
                </group>

                <group>
                    <group></group>
                    <group>
                        <field name="examination_date"/>
                        <field name="next_examination_date" readonly="1"/>
                    </group>
                </group>

                <group>
                    <group string="Type">
                        <field name="exam_type_id"/>
                        <field name="exam_type_code" readonly="1"/>
                    </group>
                    <group string="Durée">
                        <field name="validity_months" readonly="1"/>
                        <field name="validity_extra_days" readonly="1"/>
                        <field name="expiry_date" readonly="1"/>
                    </group>
                </group>

                <group string="Conclusion">
                    <field name="aptitude_result" widget="radio"/>
                    <field name="aptitude_details" nolabel="1"
                           placeholder="Préciser le poste, les EPI, les recommandations, la durée, etc."/>
                </group>

                <group string="Médecin">
                    <group>
                        <field name="doctor_name"/>
                        <field name="medical_center"/>
                    </group>
                </group>

                <group string="Observations &amp; restrictions">
                    <field name="restrictions" placeholder="Restrictions de travail" nolabel="1"/>
                    <field name="notes" placeholder="Notes du médecin" nolabel="1"/>
                </group>

                <group string="Document">
                    <field name="document"/>
                    <field name="document_name" invisible="1"/>
                </group>

                <footer>
                    <button name="action_create_medical_exam" string="Valider" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_medical_exam_wizard" model="ir.actions.act_window">
        <field name="name">+ Nouvelle Fiche d'Aptitude</field>
        <field name="res_model">medical.exam.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_medical_exam_wizard"
              name="+ Nouvelle Fiche"
              parent="employee_extended.menu_fiche_amplitude_root"
              action="action_medical_exam_wizard"
              sequence="1"/>

</odoo>