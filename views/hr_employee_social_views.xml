<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================================== -->
    <!-- Page Social - Fiche Employé                        -->
    <!-- ================================================== -->
    <record id="view_employee_form_social" model="ir.ui.view">
        <field name="name">hr.employee.form.social</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="employee_extended.view_employee_form_extended"/>
        <field name="priority">56</field>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='page_social']" position="inside">
                <group>
                        <!-- CIN -->
                        <group string="Carte d'Identité Nationale (CIN)" col="2">
                            <field name="cin_number"
                                   placeholder="8 chiffres"/>
                            <field name="cin_delivery_date"/>
                            <field name="cin_delivery_place"
                                   placeholder="Ex: Tunis, Sfax..."/>
                            <field name="cin_attachment"
                                   filename="cin_attachment_name"
                                   widget="binary"/>
                            <field name="cin_attachment_name" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <!-- CNSS -->
                        <group string="Sécurité sociale" col="2">
                            <field name="cnss_number"
                                   placeholder="Numéro CNSS"/>
                        </group>
                    </group>
            </xpath>
        </field>
    </record>
</odoo>
